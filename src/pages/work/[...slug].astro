---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
const { title, description, client, medium, year, thumbnail, images, tags } = work.data;

const allImages = images && images.length > 0 ? images : [thumbnail];
---

<BaseLayout
  title={title}
  description={description || `${title} - Illustration by Lucy Conklin`}
  image={thumbnail}
>
  <article class="work-detail">
    <div class="work-container">
      <header class="work-header">
        <h1>{title}</h1>
        <div class="work-meta">
          {client && <span class="meta-item"><strong>Client:</strong> {client}</span>}
          {medium && <span class="meta-item"><strong>Medium:</strong> {medium}</span>}
          {year && <span class="meta-item"><strong>Year:</strong> {year}</span>}
        </div>
        {tags && tags.length > 0 && (
          <div class="work-tags">
            {tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="work-images">
        {allImages.map((image: string, index: number) => (
          <figure class="work-figure">
            <img
              src={image}
              alt={index === 0 ? title : `${title} - Image ${index + 1}`}
              loading={index === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </figure>
        ))}
      </div>

      {(description || work.body) && (
        <div class="work-content">
          {description && <p class="work-description">{description}</p>}
          <Content />
        </div>
      )}

      <nav class="work-nav">
        <a href="/" class="back-link">&larr; Back to Portfolio</a>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .work-detail {
    padding: 2rem 1.5rem 4rem;
  }

  .work-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .work-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .work-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 2rem;
    color: #666;
    font-size: 0.95rem;
  }

  .meta-item strong {
    font-weight: 500;
    color: #333;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    background: #f5f5f5;
    border-radius: 20px;
    color: #666;
  }

  .work-images {
    margin-bottom: 2rem;
  }

  .work-figure {
    margin-bottom: 1.5rem;
  }

  .work-figure:last-child {
    margin-bottom: 0;
  }

  .work-figure img {
    width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .work-content {
    margin-bottom: 2rem;
    padding: 2rem 0;
    border-top: 1px solid #eee;
  }

  .work-description {
    font-size: 1.1rem;
    color: #444;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .work-content :global(p) {
    margin-bottom: 1rem;
    color: #444;
    line-height: 1.7;
  }

  .work-nav {
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #666;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #333;
  }
</style>
