---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Lucy Conklin for illustration commissions and project inquiries.">
  <article class="contact">
    <div class="contact-container">
      <h1>Contact</h1>

      <p class="lead">
        I am currently available for commissions and I would love to hear about your project!
      </p>

      <div class="contact-email">
        <a href="mailto:lucy@lucyconklin.com" class="email-link">lucy@lucyconklin.com</a>
      </div>

      <div class="contact-info">
        <p>
          Please email me for availability and pricing on original artwork.
        </p>

        <p>
          Prints and cards are available for purchase on my
          <a href="https://www.etsy.com/shop/LucyConklinArt" target="_blank" rel="noopener noreferrer">Etsy store</a>.
        </p>
      </div>

      <div class="contact-social">
        <h2>Follow Along</h2>
        <p>
          I post updates on Instagram including artwork, sketches, and nature photography.
        </p>
        <ul class="social-links">
          <li>
            <a href="https://instagram.com/lucyconklin" target="_blank" rel="noopener noreferrer">
              Instagram: @lucyconklin
            </a>
          </li>
        </ul>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .contact {
    padding: 3rem 1.5rem;
  }

  .contact-container {
    max-width: 600px;
    margin: 0 auto;
  }

  h1 {
    margin-bottom: 1.5rem;
    font-size: 2rem;
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .lead {
    font-size: 1.1rem;
    color: #444;
    margin-bottom: 2rem;
  }

  .contact-email {
    margin-bottom: 2rem;
  }

  .email-link {
    display: inline-block;
    font-size: 1.25rem;
    color: #333;
    padding: 0.75rem 1.5rem;
    border: 2px solid #27e8c9;
    border-radius: 4px;
    transition: background-color 0.2s, color 0.2s;
  }

  .email-link:hover {
    background-color: #27e8c9;
    color: #fff;
  }

  .contact-info {
    margin-bottom: 2rem;
  }

  .contact-info p {
    margin-bottom: 0.75rem;
    color: #444;
  }

  .contact-info a {
    color: #333;
    font-weight: bold;
  }

  .contact-info a:hover {
    text-decoration: underline;
  }

  .contact-social,
  .contact-newsletter {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }

  .contact-social p,
  .contact-newsletter p {
    color: #444;
    margin-bottom: 1rem;
  }

  .social-links {
    list-style: none;
    padding: 0;
  }

  .social-links li {
    margin-bottom: 0.5rem;
  }

  .social-links a {
    color: #333;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .social-links a:hover {
    color: #333;
  }
</style>
