---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Now" description="What Lucy Conklin is currently working on and focusing on.">
  <article class="now">
    <div class="now-container">
      <h1>Now</h1>

      <section class="now-section">
        <h2>Work</h2>
        <p>
          I'm based in beautiful Denver, Colorado.
        </p>
      </section>

      <section class="now-section">
        <h2>Tech Work</h2>
        <p>
          For my technical projects, writing, and professional work, visit <a href="https://lucyconklin.tech" target="_blank" rel="noopener noreferrer">lucyconklin.tech</a>. 
        </p>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .now {
    padding: 3rem 1.5rem;
  }

  .now-container {
    max-width: 600px;
    margin: 0 auto;
  }

  h1 {
    margin-bottom: 1.5rem;
    font-size: 2rem;
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .now-section {
    margin-bottom: 2rem;
  }

  .now-section p {
    color: #444;
  }

  .now-section a {
    color: #333;
    font-weight: bold;
  }

  .now-section a:hover {
    text-decoration: underline;
  }

  .now-section ul {
    color: #444;
    padding-left: 1.25rem;
  }

  .now-section li {
    margin-bottom: 0.5rem;
  }
</style>
